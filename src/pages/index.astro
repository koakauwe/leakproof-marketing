---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqSchema = [
  {
    question: 'What is SEO?',
    answer: 'SEO stands for Search Engine Optimization. It means making your website show up when someone searches Google for the services you offer. If a patient in your city types "pelvic floor therapy near me," SEO is what determines whether they find you or your competitor.',
  },
  {
    question: "Why can't I just use Instagram to get patients?",
    answer: "Instagram is great for building community, but it's not where people go when they need help right now. When someone has a health concern, they search Google — not Instagram. SEO and Google Ads put you in front of people who are actively looking for a provider today.",
  },
  {
    question: 'What makes Google Ads different for healthcare?',
    answer: "Google has strict rules about advertising health services. Certain conditions can't be targeted directly, and certain ad language gets rejected. On top of that, sensitive health searches shouldn't follow users around the internet — someone searching for help with painful intercourse shouldn't see those ads on a shared family computer. We know how to work within these rules.",
  },
  {
    question: 'How long until I see results?',
    answer: "You'll have a live website within the first month. SEO takes longer — typically 3 to 6 months to start seeing consistent organic traffic. Google Ads can generate leads within the first week of launching.",
  },
  {
    question: 'Do I own my website?',
    answer: "Yes. The code, the content, the domain — it's all yours. If you ever decide to leave, everything transfers to you. We don't hold your website hostage.",
  },
  {
    question: 'Do I have to update the website myself?',
    answer: "No — we handle everything. There's no admin panel for you to log into, no drag-and-drop editor to learn, no plugins to update. You send us a request ('update my hours,' 'add a new service page,' 'publish this blog post') and we take care of it, usually within one business day. You run your practice. We run your marketing.",
  },
  {
    question: "What does 'one client per market' mean?",
    answer: "It means we only work with one practice of your type in your geographic area. If you're a pelvic floor PT in Austin, we won't take on another pelvic floor PT in Austin. Your marketing strategy shouldn't compete against itself.",
  },
  {
    question: "Why don't you list pricing on your website?",
    answer: "Because we don't sell off-the-shelf packages. Every practice is different — your market, your current website, your goals, your timeline — and the work we'd do for you is priced to match. When we hop on a call, we'll understand what you actually need and give you a clear proposal. If we're not the right fit for you, we'll tell you that too and recommend someone who is.",
  },
  {
    question: "What if I only need help with one thing?",
    answer: "Start the conversation and tell us. We build engagements around what a practice actually needs. If that's just a new website, a Google Ads audit, or monthly content — we'll tell you honestly whether we're the right fit for that scope, what it would look like, and what it would cost.",
  },
];
---

<BaseLayout
  title="Leakproof Marketing — A Specialist Marketing Agency for Pelvic Floor PTs"
  description="We help pelvic floor physical therapists get found online with websites, SEO, Google Ads, and content built specifically for your practice. One client per market."
  faqSchema={faqSchema}
>

  <!-- ==================== HERO ==================== -->
  <section class="lp-hero" id="hero">
    <div class="container">
      <div class="lp-hero-grid">
        <div class="lp-hero-content">
          <span class="lp-hero-badge">A Marketing Agency for Pelvic Floor PTs</span>
          <h1>You Treat One Kind of Leak.<br />We Treat the Other.</h1>
          <p class="lp-hero-sub">Lost leads, poor SEO, slow sites, generic agency advice. We seal the leaks in your marketing so you can focus on what you do best.</p>
          <div class="lp-hero-actions">
            <a href="#contact" class="btn-gold">Book a Free Strategy Call</a>
            <a href="#services" class="lp-hero-link">See What We Do &darr;</a>
          </div>
          <p class="lp-hero-note">One practice per market. No competing against ourselves.</p>
        </div>

        <!-- Pipes illustration: revenue leaks being plugged by Leakproof -->
        <div class="lp-hero-illustration" aria-hidden="true">
          <svg viewBox="0 0 520 540" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Marketing pipes leaking revenue, sealed with Leakproof patches">
            <defs>
              <linearGradient id="pipe-grad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0" stop-color="#FFFFFF"/>
                <stop offset="1" stop-color="#E8EDF5"/>
              </linearGradient>
              <linearGradient id="pipe-shadow" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0" stop-color="#A8B5CC"/>
                <stop offset="1" stop-color="#6E7C99"/>
              </linearGradient>
              <filter id="pipe-soft" x="-20%" y="-20%" width="140%" height="140%">
                <feDropShadow dx="0" dy="2" stdDeviation="3" flood-opacity="0.18"/>
              </filter>
              <filter id="patch-glow">
                <feDropShadow dx="0" dy="3" stdDeviation="4" flood-color="#D4A843" flood-opacity="0.45"/>
              </filter>
            </defs>

            <!-- ================== MAIN VERTICAL PIPE (trunk) ================== -->
            <g filter="url(#pipe-soft)">
              <!-- Pipe body -->
              <rect x="60" y="20" width="50" height="500" rx="6" fill="url(#pipe-grad)"/>
              <!-- Top cap -->
              <rect x="50" y="14" width="70" height="18" rx="3" fill="url(#pipe-shadow)"/>
              <!-- Inner highlight -->
              <rect x="68" y="20" width="6" height="500" rx="3" fill="#FFFFFF" opacity="0.9"/>
            </g>

            <!-- ================== BRANCH 1: "Lost Leads" — STILL LEAKING ================== -->
            <g filter="url(#pipe-soft)">
              <!-- T-joint -->
              <rect x="100" y="82" width="32" height="36" fill="url(#pipe-shadow)" rx="3"/>
              <!-- Horizontal pipe -->
              <rect x="110" y="86" width="170" height="28" rx="4" fill="url(#pipe-grad)"/>
              <!-- Open end (leaking) -->
              <rect x="270" y="80" width="24" height="40" rx="3" fill="url(#pipe-shadow)"/>
            </g>
            <!-- Drips -->
            <circle cx="285" cy="135" r="5" fill="#D4A843" opacity="0.9"/>
            <ellipse cx="285" cy="155" rx="4" ry="6" fill="#D4A843" opacity="0.7"/>
            <circle cx="280" cy="178" r="3" fill="#D4A843" opacity="0.5"/>
            <!-- Label -->
            <g>
              <rect x="310" y="85" width="170" height="32" rx="16" fill="#1F2937" stroke="#D4A843" stroke-width="2"/>
              <text x="395" y="106" font-family="Inter, sans-serif" font-size="14" font-weight="600" fill="#FFFFFF" text-anchor="middle">Lost Leads</text>
            </g>

            <!-- ================== BRANCH 2: "Poor SEO" — PATCHED ================== -->
            <g filter="url(#pipe-soft)">
              <rect x="100" y="190" width="32" height="36" fill="url(#pipe-shadow)" rx="3"/>
              <rect x="110" y="194" width="170" height="28" rx="4" fill="url(#pipe-grad)"/>
              <rect x="270" y="188" width="24" height="40" rx="3" fill="url(#pipe-shadow)"/>
            </g>
            <!-- Patch (sealed) -->
            <g filter="url(#patch-glow)">
              <rect x="262" y="180" width="42" height="56" rx="8" fill="#D4A843"/>
              <rect x="266" y="184" width="34" height="48" rx="5" fill="#B8922E"/>
              <text x="283" y="206" font-family="Space Grotesk, sans-serif" font-size="9" font-weight="700" fill="#FFFFFF" text-anchor="middle">LEAK</text>
              <text x="283" y="218" font-family="Space Grotesk, sans-serif" font-size="9" font-weight="700" fill="#FFFFFF" text-anchor="middle">PROOF</text>
            </g>
            <!-- Label (sealed style) -->
            <g>
              <rect x="320" y="193" width="170" height="32" rx="16" fill="#D4A843"/>
              <text x="405" y="214" font-family="Inter, sans-serif" font-size="14" font-weight="700" fill="#1F2937" text-anchor="middle">Poor SEO</text>
              <!-- Checkmark -->
              <path d="M 333 209 l 4 4 l 7 -7" stroke="#1F2937" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            </g>

            <!-- ================== BRANCH 3: "Slow Site" — STILL LEAKING ================== -->
            <g filter="url(#pipe-soft)">
              <rect x="100" y="298" width="32" height="36" fill="url(#pipe-shadow)" rx="3"/>
              <rect x="110" y="302" width="170" height="28" rx="4" fill="url(#pipe-grad)"/>
              <rect x="270" y="296" width="24" height="40" rx="3" fill="url(#pipe-shadow)"/>
            </g>
            <circle cx="285" cy="350" r="5" fill="#D4A843" opacity="0.9"/>
            <ellipse cx="285" cy="370" rx="4" ry="6" fill="#D4A843" opacity="0.7"/>
            <circle cx="280" cy="392" r="3" fill="#D4A843" opacity="0.5"/>
            <g>
              <rect x="310" y="301" width="170" height="32" rx="16" fill="#1F2937" stroke="#D4A843" stroke-width="2"/>
              <text x="395" y="322" font-family="Inter, sans-serif" font-size="14" font-weight="600" fill="#FFFFFF" text-anchor="middle">Slow Site</text>
            </g>

            <!-- ================== BRANCH 4: "Generic Agency" — PATCHED ================== -->
            <g filter="url(#pipe-soft)">
              <rect x="100" y="406" width="32" height="36" fill="url(#pipe-shadow)" rx="3"/>
              <rect x="110" y="410" width="170" height="28" rx="4" fill="url(#pipe-grad)"/>
              <rect x="270" y="404" width="24" height="40" rx="3" fill="url(#pipe-shadow)"/>
            </g>
            <g filter="url(#patch-glow)">
              <rect x="262" y="396" width="42" height="56" rx="8" fill="#D4A843"/>
              <rect x="266" y="400" width="34" height="48" rx="5" fill="#B8922E"/>
              <text x="283" y="422" font-family="Space Grotesk, sans-serif" font-size="9" font-weight="700" fill="#FFFFFF" text-anchor="middle">LEAK</text>
              <text x="283" y="434" font-family="Space Grotesk, sans-serif" font-size="9" font-weight="700" fill="#FFFFFF" text-anchor="middle">PROOF</text>
            </g>
            <g>
              <rect x="320" y="409" width="170" height="32" rx="16" fill="#D4A843"/>
              <text x="405" y="430" font-family="Inter, sans-serif" font-size="14" font-weight="700" fill="#1F2937" text-anchor="middle">Generic Agency</text>
              <path d="M 333 425 l 4 4 l 7 -7" stroke="#1F2937" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            </g>

            <!-- Bottom cap -->
            <rect x="50" y="500" width="70" height="18" rx="3" fill="url(#pipe-shadow)" filter="url(#pipe-soft)"/>
          </svg>
        </div>
      </div>
    </div>
    <div class="lp-hero-shape" aria-hidden="true"></div>
  </section>

  <!-- ==================== TRUST STRIP ==================== -->
  <section class="lp-trust">
    <div class="container">
      <p class="lp-trust-label">Currently working with practices like:</p>
      <div class="lp-trust-logos">
        <a href="https://radiantpelvichealth.com" target="_blank" rel="noopener" aria-label="Radiant Pelvic Health & Wellness">
          <img src="/images/radiant-logo.webp" alt="Radiant Pelvic Health & Wellness" width="180" height="54" loading="lazy" />
        </a>
        <a href="https://lotusrosecounseling.com" target="_blank" rel="noopener" aria-label="Lotus Rose Counseling">
          <img src="/images/lotus-rose-logo.webp" alt="Lotus Rose Counseling" width="180" height="54" loading="lazy" />
        </a>
        <span class="lp-trust-yours">Yours next?</span>
      </div>
    </div>
  </section>

  <!-- ==================== WHY WE'RE DIFFERENT ==================== -->
  <section class="bg-off-white" id="difference">
    <div class="container">
      <div class="text-container">
        <span class="section-label">Why We're Different</span>
        <h2>Most Agencies Don't Know Your World. We Do.</h2>
        <p class="lp-section-intro">After a decade inside the marketing industry and hundreds of agency owners interviewed, we built Leakproof to be the partner we wished existed for practices like yours.</p>
      </div>
      <div class="lp-diff-grid">
        <div class="lp-diff-card">
          <div class="lp-diff-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="16" cy="16" r="13"/>
              <circle cx="16" cy="16" r="8"/>
              <circle cx="16" cy="16" r="3" fill="currentColor"/>
            </svg>
          </div>
          <h3>One Client Per Market</h3>
          <p>If you're our pelvic floor PT in Denver, we're not working with any other PT in Denver. Your success is our success. Not a conflict of interest.</p>
        </div>
        <div class="lp-diff-card">
          <div class="lp-diff-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 22V8a3 3 0 013-3h14a3 3 0 013 3v10a3 3 0 01-3 3h-9l-7 5z"/>
              <path d="M11 13h10M11 17h6"/>
            </svg>
          </div>
          <h3>We Speak Your Language</h3>
          <p>You don't need to explain what a pelvic floor is or why "painful intercourse" needs to be a page on your website. We already get it.</p>
        </div>
        <div class="lp-diff-card">
          <div class="lp-diff-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 4l11 4v8c0 7-5 12-11 14C10 28 5 23 5 16V8l11-4z"/>
              <path d="M11 16l3.5 3.5L21 13"/>
            </svg>
          </div>
          <h3>Privacy-First Google Ads</h3>
          <p>Healthcare advertising has rules. We know how to run Google Ads for sensitive health topics without getting your account flagged or violating your patients' privacy.</p>
        </div>
        <div class="lp-diff-card">
          <div class="lp-diff-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="5" y="9" width="22" height="16" rx="2"/>
              <path d="M5 13l11 7 11-7"/>
              <circle cx="16" cy="6" r="3"/>
            </svg>
          </div>
          <h3>No Gatekeeping</h3>
          <p>Ask us anything, whether you're a client or not. We'd rather help you succeed on your own than watch you waste money on the wrong agency.</p>
        </div>
      </div>

      <!-- Featured callout: built lean for a lean industry -->
      <div class="lp-margin-callout">
        <div class="lp-margin-callout-icon" aria-hidden="true">
          <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 2v28M22 7H13a4 4 0 000 8h6a4 4 0 010 8H10"/>
          </svg>
        </div>
        <div class="lp-margin-callout-body">
          <h3>We Don't Bill You to Learn Your Industry. We Already Know It.</h3>
          <p>We get how this business runs. Margins are tight, insurance is reimbursing less every year, and your time is the most expensive thing you have. Most agencies pass their learning curve to you in the form of billable hours and slow ramp-up. We skip that part. Leakproof was built knowing healthcare practices run lean, so the agency that serves them has to run lean too.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== SERVICES ==================== -->
  <section class="bg-white" id="services">
    <div class="container">
      <div class="text-container">
        <span class="section-label">What We Do</span>
        <h2>Six Things. All Built for Healthcare.</h2>
      </div>
      <div class="lp-services-grid">
        <div class="lp-service-card">
          <div class="lp-service-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="6" width="26" height="18" rx="2"/>
              <path d="M3 11h26M12 28h8M16 24v4"/>
              <circle cx="7" cy="8.5" r="0.6" fill="currentColor"/>
              <circle cx="9.5" cy="8.5" r="0.6" fill="currentColor"/>
            </svg>
          </div>
          <h3>Websites That Work</h3>
          <p>Not just pretty. Fast, accessible, and built to convert visitors into patients. Our sites score near-perfect on Google's performance tests while your competitors' sites choke on bloated plugins.</p>
        </div>
        <div class="lp-service-card">
          <div class="lp-service-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="14" cy="14" r="9"/>
              <path d="M21 21l6 6"/>
              <path d="M10 14h8M14 10v8"/>
            </svg>
          </div>
          <h3>SEO That Actually Matters</h3>
          <p>We write the pages your future patients are searching for. When someone Googles "pelvic floor therapy near me," you show up. Not your competitor down the street.</p>
        </div>
        <div class="lp-service-card">
          <div class="lp-service-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 4h14l6 6v18a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2z"/>
              <path d="M20 4v6h6"/>
              <path d="M9 16h14M9 20h14M9 24h9"/>
            </svg>
          </div>
          <h3>Content That Educates</h3>
          <p>Blog posts, FAQs, and resources that answer your patients' real questions. We build a content tree so every piece works together to bring patients to your door.</p>
        </div>
        <div class="lp-service-card">
          <div class="lp-service-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 21l8-8 5 5 9-9"/>
              <path d="M19 9h6v6"/>
              <path d="M3 27h26"/>
            </svg>
          </div>
          <h3>Google Ads for Healthcare</h3>
          <p>Reach patients who are actively searching for help right now without violating Google's sensitive health policies. We handle strategy, ad copy, and ongoing optimization.</p>
        </div>
        <div class="lp-service-card">
          <div class="lp-service-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 3c-5.5 0-10 4.5-10 10 0 7 10 16 10 16s10-9 10-16c0-5.5-4.5-10-10-10z"/>
              <circle cx="16" cy="13" r="3.5" fill="currentColor"/>
            </svg>
          </div>
          <h3>Google Business Profile</h3>
          <p>Your GBP is often the first thing patients see. We keep it active with regular posts, photos, and a review strategy that builds trust before they ever visit your site.</p>
        </div>
        <div class="lp-service-card">
          <div class="lp-service-icon" aria-hidden="true">
            <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 27V5"/>
              <path d="M5 27h22"/>
              <rect x="9" y="17" width="4" height="8" fill="currentColor" stroke="none"/>
              <rect x="15" y="11" width="4" height="14" fill="currentColor" stroke="none"/>
              <rect x="21" y="14" width="4" height="11" fill="currentColor" stroke="none"/>
            </svg>
          </div>
          <h3>Analytics & Reporting</h3>
          <p>Proper Google Analytics setup, Search Console tracking, and monthly reports that tell you what's actually working. No vanity metrics. Just patients through the door and how they got there.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== RESULTS ==================== -->
  <section class="bg-off-white" id="results">
    <div class="container">
      <div class="text-container">
        <span class="section-label">Results</span>
        <h2>What Happens When Marketing Actually Fits</h2>
        <p class="lp-section-intro">These aren't hypothetical case studies. These are real practices we work with.</p>
      </div>
      <div class="lp-results-grid">
        <div class="lp-result-card lp-result-active">
          <div class="lp-result-badge">Active Client</div>
          <h3><a href="https://radiantpelvichealth.com" target="_blank" rel="noopener" class="lp-result-name">Radiant Pelvic Health & Wellness</a></h3>
          <p class="lp-result-type">Pelvic Floor Physical Therapy &bull; Utah Valley</p>
          <ul class="lp-result-metrics">
            <li>Website built from scratch on a high-performance framework</li>
            <li>20+ SEO-optimized condition and treatment pages</li>
            <li>Weekly blog content program launched</li>
            <li>Google Ads campaigns generating patient inquiries</li>
            <li>Google Business Profile active with 5-star rating</li>
            <li>Showing up in AI search results (ChatGPT) within months</li>
          </ul>
          <blockquote class="lp-testimonial">
            <p>"Koa built me a website that actually brings patients in. Real ones, not just traffic numbers. He cares about my practice like it's his own."</p>
            <footer>
              <strong>Dr. Danaya Kauwe, PT, DPT, PRPC</strong>
              <span>Founder, Radiant Pelvic Health & Wellness</span>
            </footer>
          </blockquote>
        </div>
        <div class="lp-result-card">
          <div class="lp-result-badge">Active Client</div>
          <h3><a href="https://lotusrosecounseling.com" target="_blank" rel="noopener" class="lp-result-name">Lotus Rose Counseling</a></h3>
          <p class="lp-result-type">Women's Mental Health &bull; Orem, Utah</p>
          <ul class="lp-result-metrics">
            <li>Joy Bouchard, LCSW &mdash; founder and therapist</li>
            <li>Specializes in perinatal mental health, trauma, and grief</li>
            <li>EMDR and Accelerated Resolution Therapy trained</li>
            <li>Serves Utah County + statewide telehealth</li>
            <li>Custom website, SEO, and analytics underway</li>
          </ul>
        </div>
        <div class="lp-result-card">
          <div class="lp-result-badge lp-badge-soon">Coming Soon</div>
          <h3>Your Practice?</h3>
          <p class="lp-result-type">We're selectively taking on new clients</p>
          <p class="lp-result-status">If your market is open, let's talk about what we can build together.</p>
          <a href="#contact" class="lp-result-link">Check availability &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== HOW WE WORK ==================== -->
  <section class="bg-white" id="approach">
    <div class="container">
      <div class="text-container text-center" style="margin: 0 auto;">
        <span class="section-label">How We Work</span>
        <h2>The Wrong Marketing Agency Is Its Own Leak.</h2>
        <p class="lp-section-intro">The kind you don't notice until you've spent months and thousands trying to fix it. You won't solve it with a quick Google search, and you shouldn't try to. You need a specialist who actually understands your practice, and a real conversation to know if we're a fit.</p>
      </div>
      <div class="lp-approach-grid">
        <div class="lp-approach-step">
          <span class="lp-step-num">01</span>
          <h3>We Have a Real Conversation</h3>
          <p>Thirty minutes on a call. You tell us about your practice, your patients, what's working, what's frustrating, and where you want to be in a year. No pitch deck, no hard sell.</p>
        </div>
        <div class="lp-approach-step">
          <span class="lp-step-num">02</span>
          <h3>We Assess Honestly</h3>
          <p>We look at your website, your search visibility, your local market, and your current marketing. Then we tell you the truth about what we think is needed &mdash; even if it's less than what your current agency is billing for.</p>
        </div>
        <div class="lp-approach-step">
          <span class="lp-step-num">03</span>
          <h3>We Tell You If We're a Fit</h3>
          <p>If we're the right partner for what you need, we'll put together a proposal tailored to your goals. If we're not &mdash; if you need something we don't do, or a different approach &mdash; we'll say so and recommend someone who is.</p>
        </div>
      </div>
      <div class="lp-approach-footer">
        <p><strong>The kinds of things we build into engagements:</strong> custom websites on a static framework, dedicated condition landing pages, local search optimization, Google Ads for healthcare (with the privacy rules that apply), content strategy and ongoing publishing, Google Business Profile management, and analytics setup so you actually know what's working.</p>
        <p class="lp-approach-note">Every engagement is fully managed. You don't touch a dashboard, you don't learn a tool. You send requests, we deliver.</p>
      </div>
      <div class="text-center" style="margin-top: 40px;">
        <a href="#contact" class="btn-primary">Start the Conversation</a>
