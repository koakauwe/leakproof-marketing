---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqSchema = [
  {
    question: 'What is SEO?',
    answer: 'SEO stands for Search Engine Optimization. It means making your website show up when someone searches Google for the services you offer. If a patient in your city types "pelvic floor therapy near me," SEO is what determines whether they find you or your competitor.',
  },
  {
    question: "Why can't I just use Instagram to get patients?",
    answer: "Instagram is great for building community, but it's not where people go when they need help right now. When someone has a health concern, they search Google — not Instagram. SEO and Google Ads put you in front of people who are actively looking for a provider today.",
  },
  {
    question: 'What makes Google Ads different for healthcare?',
    answer: "Google has strict rules about advertising health services. Certain conditions can't be targeted directly, and certain ad language gets rejected. On top of that, sensitive health searches shouldn't follow users around the internet — someone searching for help with painful intercourse shouldn't see those ads on a shared family computer. We know how to work within these rules.",
  },
  {
    question: 'How long until I see results?',
    answer: "You'll have a live website within the first month. SEO takes longer — typically 3 to 6 months to start seeing consistent organic traffic. Google Ads can generate leads within the first week of launching.",
  },
  {
    question: 'Do I own my website?',
    answer: "Yes. The code, the content, the domain — it's all yours. If you ever decide to leave, everything transfers to you. We don't hold your website hostage.",
  },
  {
    question: 'Do I have to update the website myself?',
    answer: "No — we handle everything. There's no admin panel for you to log into, no drag-and-drop editor to learn, no plugins to update. You send us a request ('update my hours,' 'add a new service page,' 'publish this blog post') and we take care of it, usually within one business day. You run your practice. We run your marketing.",
  },
  {
    question: "What does 'one client per market' mean?",
    answer: "It means we only work with one practice of your type in your geographic area. If you're a pelvic floor PT in Austin, we won't take on another pelvic floor PT in Austin. Your marketing strategy shouldn't compete against itself.",
  },
  {
    question: "Why don't you list pricing on your website?",
    answer: "Because we don't sell off-the-shelf packages. Every practice is different — your market, your current website, your goals, your timeline — and the work we'd do for you is priced to match. When we hop on a call, we'll understand what you actually need and give you a clear proposal. If we're not the right fit for you, we'll tell you that too and recommend someone who is.",
  },
  {
    question: "What if I only need help with one thing?",
    answer: "Start the conversation and tell us. We build engagements around what a practice actually needs. If that's just a new website, a Google Ads audit, or monthly content — we'll tell you honestly whether we're the right fit for that scope, what it would look like, and what it would cost.",
  },
];
---

<BaseLayout
  title="Leakproof Marketing — Digital Marketing for Pelvic Floor PTs & Counselors"
  description="We help pelvic floor physical therapists and counselors get found online with websites, SEO, Google Ads, and content built for your world. One client per market."
  faqSchema={faqSchema}
>

  <!-- ==================== HERO ==================== -->
  <section class="lp-hero" id="hero">
    <div class="container">
      <div class="lp-hero-content">
        <span class="lp-hero-badge">Marketing for Healthcare Practices</span>
        <h1>Your Patients Are Looking for You.<br />They Just Can't Find You.</h1>
        <p class="lp-hero-sub">We help pelvic floor PTs and counselors get found online — with websites, SEO, and Google Ads built for your world.</p>
        <div class="lp-hero-actions">
          <a href="#contact" class="btn-gold">Book a Free Strategy Call</a>
          <a href="#services" class="lp-hero-link">See What We Do &darr;</a>
        </div>
        <p class="lp-hero-note">One client per market. No competing against ourselves.</p>
      </div>
    </div>
    <div class="lp-hero-shape" aria-hidden="true"></div>
  </section>

  <!-- ==================== WHY WE'RE DIFFERENT ==================== -->
  <section class="bg-off-white" id="difference">
    <div class="container">
      <div class="text-container">
        <span class="section-label">Why We're Different</span>
        <h2>We Spent a Decade Inside the Agency World. We Know What Goes Wrong.</h2>
        <p class="lp-section-intro">After years of working with hundreds of marketing agencies, we built Leakproof to be the kind of partner we wished existed — one that actually understands your practice.</p>
      </div>
      <div class="lp-diff-grid">
        <div class="lp-diff-card">
          <div class="lp-diff-icon">&#x1F3AF;</div>
          <h3>One Client Per Market</h3>
          <p>If you're our pelvic floor PT in Denver, we're not working with any other PT in Denver. Your success is our success — not a conflict of interest.</p>
        </div>
        <div class="lp-diff-card">
          <div class="lp-diff-icon">&#x1F4AC;</div>
          <h3>We Speak Your Language</h3>
          <p>You don't need to explain what a pelvic floor is or why "painful intercourse" needs to be a page on your website. We already get it.</p>
        </div>
        <div class="lp-diff-card">
          <div class="lp-diff-icon">&#x1F512;</div>
          <h3>Privacy-First Google Ads</h3>
          <p>Healthcare advertising has rules. We know how to run Google Ads for sensitive health topics without getting your account flagged — or violating your patients' privacy.</p>
        </div>
        <div class="lp-diff-card">
          <div class="lp-diff-icon">&#x1F91D;</div>
          <h3>No Gatekeeping</h3>
          <p>Ask us anything — whether you're a client or not. We'd rather help you succeed on your own than watch you waste money on the wrong agency.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== SERVICES ==================== -->
  <section class="bg-white" id="services">
    <div class="container">
      <div class="text-container">
        <span class="section-label">What We Do</span>
        <h2>Everything Your Practice Needs to Get Found</h2>
      </div>
      <div class="lp-services-grid">
        <div class="lp-service-card">
          <div class="lp-service-icon">&#x1F4BB;</div>
          <h3>Websites That Work</h3>
          <p>Not just pretty — fast, accessible, and built to convert visitors into patients. Our sites score near-perfect on Google's performance tests while your competitors' sites choke on bloated plugins.</p>
        </div>
        <div class="lp-service-card">
          <div class="lp-service-icon">&#x1F50D;</div>
          <h3>SEO That Actually Matters</h3>
          <p>We write the pages your future patients are searching for. When someone Googles "pelvic floor therapy near me," you show up — not your competitor down the street.</p>
        </div>
        <div class="lp-service-card">
          <div class="lp-service-icon">&#x270D;&#xFE0F;</div>
          <h3>Content That Educates</h3>
          <p>Blog posts, FAQs, and resources that answer your patients' real questions. We build a content tree so every piece works together to bring patients to your door.</p>
        </div>
        <div class="lp-service-card">
          <div class="lp-service-icon">&#x1F4B0;</div>
          <h3>Google Ads for Healthcare</h3>
          <p>Reach patients who are actively searching for help right now — without violating Google's sensitive health policies. We handle strategy, ad copy, and ongoing optimization.</p>
        </div>
        <div class="lp-service-card">
          <div class="lp-service-icon">&#x1F4CD;</div>
          <h3>Google Business Profile</h3>
          <p>Your GBP is often the first thing patients see. We keep it active with regular posts, photos, and a review strategy that builds trust before they ever visit your site.</p>
        </div>
        <div class="lp-service-card">
          <div class="lp-service-icon">&#x1F4CA;</div>
          <h3>Analytics & Reporting</h3>
          <p>Proper Google Analytics setup, Search Console tracking, and monthly reports that tell you what's actually working. No vanity metrics, just patients through the door and how they got there.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== RESULTS ==================== -->
  <section class="bg-off-white" id="results">
    <div class="container">
      <div class="text-container">
        <span class="section-label">Results</span>
        <h2>What Happens When Marketing Actually Fits</h2>
        <p class="lp-section-intro">These aren't hypothetical case studies. These are real practices we work with.</p>
      </div>
      <div class="lp-results-grid">
        <div class="lp-result-card lp-result-active">
          <div class="lp-result-badge">Active Client</div>
          <h3><a href="https://radiantpelvichealth.com" target="_blank" rel="noopener" class="lp-result-name">Radiant Pelvic Health & Wellness</a></h3>
          <p class="lp-result-type">Pelvic Floor Physical Therapy &bull; Utah Valley</p>
          <ul class="lp-result-metrics">
            <li>Website built from scratch on a high-performance framework</li>
            <li>20+ SEO-optimized condition and treatment pages</li>
            <li>Weekly blog content program launched</li>
            <li>Google Ads campaigns generating patient inquiries</li>
            <li>Google Business Profile active with 5-star rating</li>
            <li>Showing up in AI search results (ChatGPT) within months</li>
          </ul>
        </div>
        <div class="lp-result-card">
          <div class="lp-result-badge">Active Client</div>
          <h3><a href="https://lotusrosecounseling.com" target="_blank" rel="noopener" class="lp-result-name">Lotus Rose Counseling</a></h3>
          <p class="lp-result-type">Women's Mental Health &bull; Orem, Utah</p>
          <ul class="lp-result-metrics">
            <li>Joy Bouchard, LCSW &mdash; founder and therapist</li>
            <li>Specializes in perinatal mental health, trauma, and grief</li>
            <li>EMDR and Accelerated Resolution Therapy trained</li>
            <li>Serves Utah County + statewide telehealth</li>
            <li>Custom website, SEO, and analytics underway</li>
          </ul>
        </div>
        <div class="lp-result-card">
          <div class="lp-result-badge lp-badge-soon">Coming Soon</div>
          <h3>Your Practice?</h3>
          <p class="lp-result-type">We're selectively taking on new clients</p>
          <p class="lp-result-status">If your market is open, let's talk about what we can build together.</p>
          <a href="#contact" class="lp-result-link">Check availability &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== HOW WE WORK ==================== -->
  <section class="bg-white" id="approach">
    <div class="container">
      <div class="text-container text-center" style="margin: 0 auto;">
        <span class="section-label">How We Work</span>
        <h2>We Don't Sell Packages. We Build Partnerships.</h2>
        <p class="lp-section-intro">Your practice isn't a template and neither is our engagement. Before we talk numbers, we talk about what your practice actually needs to grow &mdash; and whether we're the right people to help you get there.</p>
      </div>
      <div class="lp-approach-grid">
        <div class="lp-approach-step">
          <span class="lp-step-num">01</span>
          <h3>We Have a Real Conversation</h3>
          <p>Thirty minutes on a call. You tell us about your practice, your patients, what's working, what's frustrating, and where you want to be in a year. No pitch deck, no hard sell.</p>
        </div>
        <div class="lp-approach-step">
          <span class="lp-step-num">02</span>
          <h3>We Assess Honestly</h3>
          <p>We look at your website, your search visibility, your local market, and your current marketing. Then we tell you the truth about what we think is needed &mdash; even if it's less than what your current agency is billing for.</p>
        </div>
        <div class="lp-approach-step">
          <span class="lp-step-num">03</span>
          <h3>We Tell You If We're a Fit</h3>
          <p>If we're the right partner for what you need, we'll put together a proposal tailored to your goals. If we're not &mdash; if you need something we don't do, or a different approach &mdash; we'll say so and recommend someone who is.</p>
        </div>
      </div>
      <div class="lp-approach-footer">
        <p><strong>The kinds of things we build into engagements:</strong> custom websites on a static framework, dedicated condition landing pages, local search optimization, Google Ads for healthcare (with the privacy rules that apply), content strategy and ongoing publishing, Google Business Profile management, and analytics setup so you actually know what's working.</p>
        <p class="lp-approach-note">Every engagement is fully managed. You don't touch a dashboard, you don't learn a tool. You send requests, we deliver.</p>
      </div>
      <div class="text-center" style="margin-top: 40px;">
        <a href="#contact" class="btn-primary">Start the Conversation</a>
      </div>
    </div>
  </section>

  <!-- ==================== FAQ ==================== -->
  <section class="bg-off-white" id="faq">
    <div class="container">
      <div class="text-container">
        <span class="section-label">Common Questions</span>
        <h2>You've Got Questions. Good.</h2>
      </div>
      <div class="lp-faq-list">
        {faqSchema.map((faq) => (
          <details class="faq-item">
            <summary>{faq.question}</summary>
            <div class="faq-answer">
              <p>{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== ABOUT ==================== -->
  <section class="bg-white" id="about">
    <div class="container">
      <div class="lp-about-grid">
        <div class="lp-about-content">
          <span class="section-label">Meet Koa</span>
          <h2>I Spent 10 Years Watching Agencies Get It Wrong.</h2>
          <p>I've worked inside the digital marketing industry for nearly a decade. I've helped hundreds of agencies with their operations and interviewed nine agency owners a week for months. I've seen practices pour thousands into marketing that never moved the needle — because the agency didn't understand their world.</p>
          <p>Pelvic floor PTs and counselors have unique challenges. Your services are sensitive. Your patients are nervous. And most agencies treat you like any other small business.</p>
          <p>I started Leakproof because I believe you deserve a marketing partner who actually understands what you do — and who cares enough to learn the difference between a pelvic floor spasm and pelvic floor weakness before writing your website copy.</p>
          <p>I'm not trying to build a big agency. I'm trying to help a small number of practices really well. If you have questions — about marketing, about your website, about whether any of this is worth it — <a href="#contact">reach out</a>. I'll give you a straight answer whether you become a client or not.</p>
        </div>
        <div class="lp-about-photo">
          <div class="lp-photo-placeholder">
            <span>Photo<br/>Coming Soon</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== CONTACT ==================== -->
  <section class="bg-off-white" id="contact">
    <div class="container">
      <div class="lp-contact-wrap">
        <span class="section-label">Get Started</span>
        <h2>Let's See If We're a Fit</h2>
        <p class="lp-section-intro">One quick call. No pitch deck. No pressure. Just a conversation about your practice and whether we can help.</p>
        <div class="lp-contact-actions">
          <a href="mailto:hello@leakproofmarketing.com" class="btn-gold">Email hello@leakproofmarketing.com</a>
        </div>
        <p class="lp-contact-note">We only take one client per market. If your area is open, let's talk before your competitor does.</p>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ==================== HERO ==================== */
  .lp-hero {
    background: linear-gradient(135deg, #4A6FA5 0%, #3B5A87 40%, #2B2B2B 100%);
    color: var(--white);
    padding: 120px 0 140px;
    position: relative;
    overflow: hidden;
  }

  .lp-hero-shape {
    position: absolute;
    top: -200px;
    right: -200px;
    width: 600px;
    height: 600px;
    background: rgba(212, 168, 67, 0.08);
    border-radius: 50%;
    pointer-events: none;
  }

  .lp-hero-content {
    max-width: 720px;
    position: relative;
    z-index: 1;
  }

  .lp-hero-badge {
    display: inline-block;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--warm-gold);
    margin-bottom: 24px;
  }

  .lp-hero h1 {
    color: var(--white);
    font-size: 56px;
    line-height: 1.1;
    margin-bottom: 24px;
  }

  .lp-hero-sub {
    font-size: 20px;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.6;
    margin-bottom: 36px;
    max-width: 580px;
  }

  .lp-hero-actions {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }

  .lp-hero-link {
    color: rgba(255, 255, 255, 0.7) !important;
    font-weight: 500;
    font-size: 16px;
    transition: color var(--transition-smooth);
  }
  .lp-hero-link:hover {
    color: var(--white) !important;
  }

  .lp-hero-note {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.5);
    font-style: italic;
    margin: 0;
  }

  /* ==================== DIFFERENCE ==================== */
  .lp-section-intro {
    font-size: 19px;
    color: var(--text-medium);
    line-height: 1.7;
    margin-bottom: 0;
  }

  .lp-diff-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-top: 48px;
  }

  .lp-diff-card {
    background: var(--white);
    padding: 36px;
    border-radius: 12px;
    border: 1px solid var(--border-light);
    transition: box-shadow var(--transition-smooth);
  }

  .lp-diff-card:hover {
    box-shadow: var(--shadow-medium);
  }

  .lp-diff-icon {
    font-size: 28px;
    margin-bottom: 16px;
  }

  .lp-diff-card h3 {
    font-size: 22px;
    margin-bottom: 12px;
  }

  .lp-diff-card p {
    font-size: 16px;
    line-height: 1.7;
    color: var(--text-medium);
    margin: 0;
  }

  /* ==================== SERVICES ==================== */
  .lp-services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 48px;
  }

  .lp-service-card {
    background: var(--off-white);
    padding: 32px;
    border-radius: 12px;
    border-left: 3px solid var(--slate-blue);
    transition: all var(--transition-smooth);
  }

  .lp-service-card:hover {
    box-shadow: var(--shadow-medium);
    transform: translateY(-2px);
  }

  .lp-service-icon {
    font-size: 28px;
    margin-bottom: 12px;
  }

  .lp-service-card h3 {
    font-size: 20px;
    margin-bottom: 10px;
  }

  .lp-service-card p {
    font-size: 15px;
    line-height: 1.7;
    color: var(--text-medium);
    margin: 0;
  }

  /* ==================== RESULTS ==================== */
  .lp-results-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 48px;
  }

  .lp-result-card {
    background: var(--white);
    padding: 32px;
    border-radius: 12px;
    border: 1px solid var(--border-light);
    position: relative;
  }

  .lp-result-active {
    border-color: var(--warm-gold);
    border-width: 2px;
  }

  .lp-result-badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--white);
    background: var(--warm-gold-dark);
    padding: 4px 12px;
    border-radius: 20px;
    margin-bottom: 16px;
  }

  .lp-badge-soon {
    background: var(--text-light);
  }

  .lp-result-card h3 {
    font-size: 22px;
    margin-bottom: 8px;
  }

  .lp-result-type {
    font-size: 14px;
    color: var(--text-light);
    margin-bottom: 16px;
  }

  .lp-result-metrics {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .lp-result-metrics li {
    padding: 8px 0;
    padding-left: 24px;
    font-size: 15px;
    color: var(--text-medium);
    position: relative;
    border-bottom: 1px solid var(--off-white);
  }

  .lp-result-metrics li::before {
    content: '\2713';
    position: absolute;
    left: 0;
    color: var(--warm-gold-dark);
    font-weight: 700;
  }

  .lp-result-metrics li:last-child {
    border-bottom: none;
  }

  .lp-result-status {
    font-size: 15px;
    color: var(--text-medium);
  }

  .lp-result-name {
    color: var(--text-dark);
    text-decoration: none;
    transition: color var(--transition-smooth);
  }
  .lp-result-name:hover {
    color: var(--slate-blue);
  }

  .lp-result-link {
    display: inline-block;
    margin-top: 12px;
    font-size: 15px;
    font-weight: 600;
    color: var(--slate-blue);
  }

  /* ==================== HOW WE WORK ==================== */
  .lp-approach-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-top: 56px;
  }

  .lp-approach-step {
    background: var(--off-white);
    padding: 40px 32px 36px;
    border-radius: 14px;
    border-top: 4px solid var(--slate-blue);
    position: relative;
  }

  .lp-step-num {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 42px;
    font-weight: 700;
    color: var(--warm-gold);
    line-height: 1;
    display: block;
    margin-bottom: 12px;
    letter-spacing: -1px;
  }

  .lp-approach-step h3 {
    font-size: 22px;
    margin-bottom: 12px;
  }

  .lp-approach-step p {
    font-size: 16px;
    line-height: 1.7;
    color: var(--text-medium);
    margin: 0;
  }

  .lp-approach-footer {
    max-width: 820px;
    margin: 56px auto 0;
    text-align: center;
  }

  .lp-approach-footer p {
    font-size: 17px;
    line-height: 1.7;
    color: var(--text-medium);
  }

  .lp-approach-note {
    font-size: 15px !important;
    color: var(--text-light) !important;
    font-style: italic;
    margin-top: 8px !important;
  }

  /* ==================== PRICING (kept for backward compat, unused) ==================== */
  .lp-pricing-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-top: 48px;
  }

  .lp-price-card {
    background: var(--off-white);
    padding: 32px 24px;
    border-radius: 12px;
    border: 2px solid transparent;
    text-align: center;
    position: relative;
    transition: all var(--transition-smooth);
  }

  .lp-price-card:hover {
    border-color: var(--slate-blue);
    box-shadow: var(--shadow-medium);
  }

  .lp-price-featured {
    background: var(--slate-blue);
    color: var(--white);
    transform: scale(1.04);
    border-color: var(--slate-blue);
  }

  .lp-price-featured:hover {
    transform: scale(1.06);
  }

  .lp-price-tag {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--warm-gold);
    color: var(--text-dark);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 4px 16px;
    border-radius: 20px;
    white-space: nowrap;
  }

  .lp-price-card h3 {
    font-size: 20px;
    margin-bottom: 8px;
  }

  .lp-price-featured h3 {
    color: var(--white);
  }

  .lp-price {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 42px;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 24px;
  }

  .lp-price span {
    font-size: 16px;
    font-weight: 400;
    color: var(--text-medium);
  }

  .lp-price-featured .lp-price {
    color: var(--white);
  }

  .lp-price-featured .lp-price span {
    color: rgba(255, 255, 255, 0.7);
  }

  .lp-price-features {
    list-style: none;
    padding: 0;
    margin: 0;
    text-align: left;
  }

  .lp-price-features li {
    padding: 10px 0;
    font-size: 14px;
    color: var(--text-medium);
    border-bottom: 1px solid var(--border-light);
    padding-left: 24px;
